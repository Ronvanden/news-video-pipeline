    "selection_rules": [
      {
        "condition": "If the topic is broad, neutral or hard to classify",
        "use_template": "documentary"
      },
      {
        "condition": "If the source is a news article and needs context",
        "use_template": "news_explainer"
      },
      {
        "condition": "If the story involves forgotten places, old buildings or historical mystery",
        "use_template": "mystery_history"
      },
      {
        "condition": "If the story involves crime, investigation or unresolved incidents",
        "use_template": "true_crime"
      },
      {
        "condition": "If the story is mainly human, emotional or motivational",
        "use_template": "emotional_story"
      },
      {
        "condition": "If the story involves property, buildings, market value or transformation",
        "use_template": "real_estate_story"
      }
    ],
    "global_rules": [
      "Do not invent facts.",
      "Separate confirmed facts from interpretation.",
      "Use warnings for uncertain or incomplete information.",
      "Prefer documentary or news_explainer for unclear topics.",
      "Avoid too many templates before real production testing."
    ]
