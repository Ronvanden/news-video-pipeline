# Lokale Entwicklung: Kopiere nach .env (nicht committen).
# In Produktion (z. B. Cloud Run): Variablen/Secrets zur Laufzeit setzen, nicht ins Image.

# Optional: OpenAI — nur über Umgebung/Secret, nie in Logs oder Git
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# Phase 7.2 Preview (optional): OpenAI Speech — nutzt gleiches OPENAI_API_KEY wie LLM wenn gesetzt.
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=alloy
# ENABLE_VOICE_SYNTH_PREVIEW_BODY=false
# VOICE_SYNTH_PREVIEW_MAX_BYTES=262144
# (JSON response_format braucht ein Modell mit JSON-Mode; z. B. gpt-4o-mini, gpt-4o, gpt-3.5-turbo-1106+)

# BA 6.6.1 Nur lokal/integration: POST /dev/fixtures/completed-script-job — completed ScriptJob ohne YouTube
# ENABLE_TEST_FIXTURES=false

# BA 26.2 / BA 26.4 — Runway Image-to-Video (Smoke; nur Umgebung/Secret)
# RUNWAY_API_KEY=

# BA 26.4 — Google Veo (Live-Smoke im Repo noch nicht angebunden; ENV-Name für spätere Anbindung)
# GOOGLE_VEO_API_KEY=

# BA 19.0 / BA 26.8 — Leonardo AI (Bilder; Asset Runner --mode live)
# LEONARDO_API_KEY=
# LEONARDO_API_ENDPOINT=https://cloud.leonardo.ai/api/rest/v1/generations
# LEONARDO_MODEL_ID=

# BA 26.7 / BA 26.8 — ElevenLabs (Voice; --voice-mode elevenlabs)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=
